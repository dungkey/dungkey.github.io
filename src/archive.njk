---
layout: layouts/base.njk
title: 全部文章
description: 开发、设计与思考方向的全部文章。
permalink: /archive/
---

<header class="inner-hero inner-hero--quiet">
  <span class="inner-kicker">归档</span>
  <h1 class="inner-title">全部文章</h1>
  <div class="inner-meta">
    <span>{{ collections.posts.length }} 篇</span>
  </div>
</header>

<nav class="direction-pills" aria-label="按方向浏览">
  {% for item in directions %}
    <a href="/{{ item.slug }}/">{{ item.key }}</a>
  {% endfor %}
</nav>

<section aria-labelledby="archive-articles">
  <h2 class="visually-hidden" id="archive-articles">文章</h2>
  <ul class="post-list">
  {% for post in collections.posts %}
    <li>
      <a class="post-list-item" href="{{ post.url }}">
        <h3 class="post-list-title">{{ post.data.title }}</h3>
        <p class="post-list-excerpt">
          {{ post.data.description or (post.templateContent | excerpt) }}
        </p>
        <div class="post-list-meta">
          {{ post.data.category }}
          · {{ post.date | readableDate }}
        </div>
      </a>
    </li>
  {% else %}
    <li class="empty-state">暂无文章。</li>
  {% endfor %}
  </ul>
</section>
