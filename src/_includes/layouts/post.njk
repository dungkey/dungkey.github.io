---
layout: layouts/base.njk
---

<article class="article-page">
  <header class="article-hero">
    <span class="inner-kicker">
      {% set direction = directions | directionByKey(category) %}
      {% if direction %}<a href="/{{ direction.slug }}/">{{ category }}</a>{% else %}{{ category or "文章" }}{% endif %}
      · {{ date | readableDate }}
    </span>
    <h1 class="article-title">{{ title }}</h1>
    <div class="inner-meta">
      <span>{{ content | readingTime }} 分钟阅读</span>
      {% if tags %}
        {% set visibleTags = tags | publicTags %}
        {% if visibleTags.length %}<span>{{ visibleTags | join(" · ") }}</span>{% endif %}
      {% endif %}
    </div>
  </header>

  <div class="prose">
    {{ content | safe }}
  </div>

  {% set newerPost = collections.posts | getPreviousCollectionItem %}
  {% set olderPost = collections.posts | getNextCollectionItem %}
  {% if olderPost or newerPost %}
    <nav class="post-nav" aria-label="上下篇文章">
      {% if olderPost %}
        <a href="{{ olderPost.url }}">
          <span class="post-nav-label">更早</span>
          <span class="post-nav-title">{{ olderPost.data.title }}</span>
        </a>
      {% else %}
        <div></div>
      {% endif %}
      {% if newerPost %}
        <a href="{{ newerPost.url }}">
          <span class="post-nav-label">更新</span>
          <span class="post-nav-title">{{ newerPost.data.title }}</span>
        </a>
      {% endif %}
    </nav>
  {% endif %}
</article>
