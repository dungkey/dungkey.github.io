<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="{{ site.name }} 首页">
      <img
        class="brand-logo brand-logo--light"
        src="/assets/img/logo-light.png"
        alt="{{ site.name }} · {{ site.alias }}"
        width="160"
        height="58"
        decoding="async"
      />
      <img
        class="brand-logo brand-logo--dark"
        src="/assets/img/logo-dark.png"
        alt="{{ site.name }} · {{ site.alias }}"
        width="160"
        height="58"
        decoding="async"
      />
    </a>

    <nav class="nav" aria-label="内容方向">
      {% for item in directions %}
        <a
          href="/{{ item.slug }}/"
          {% if page.url == "/" + item.slug + "/" %}aria-current="page"{% endif %}
        >{{ item.key }}</a>
      {% endfor %}
    </nav>

    <div class="header-end">
      <a class="about-link" href="{% if isHome %}#about{% else %}/#about{% endif %}">About</a>
      <button
        class="icon-trigger music-toggle"
        id="musicToggle"
        aria-label="播放背景音乐"
        aria-pressed="false"
        type="button"
      >
        <span class="music-eq" aria-hidden="true">
          <i></i><i></i><i></i>
        </span>
      </button>
      <button class="icon-trigger" id="themeToggle" aria-label="切换深色模式" type="button">
        <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9 7 7M17 17l2.1 2.1M19.1 4.9 17 7M7 17l-2.1 2.1"></path>
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19 13.5A7.5 7.5 0 1 1 10.5 5 6 6 0 0 0 19 13.5z"></path>
        </svg>
      </button>
      <button class="icon-trigger" id="searchOpen" aria-label="搜索文章标题" type="button">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5"></circle>
          <path d="M15.5 15.5 21 21"></path>
        </svg>
      </button>
    </div>
  </div>
</header>
