<a class="article" href="{{ post.url }}" aria-label="阅读文章：{{ post.data.title }}">
  <div class="article-no">A / {{ index | padNum }}</div>
  <div class="article-main">
    <div class="meta">
      {{ post.data.category or "随笔" }}
      · {{ post.templateContent | readingTime }} 分钟阅读
      · {{ post.date | readableDate }}
    </div>
    <h3 class="article-title">{{ post.data.title }}</h3>
    <p class="article-excerpt">
      {{ post.data.description or (post.templateContent | excerpt) }}
    </p>
  </div>
  <div class="article-tags">
    {% for tag in post.data.tags or [] %}
      {% if tag != "posts" %}
        <span class="tag">{{ tag }}</span>
      {% endif %}
    {% endfor %}
  </div>
  <span class="arrow-box" aria-hidden="true">
    <svg class="icon" viewBox="0 0 24 24">
      <path d="M5 19 19 5M9 5h10v10"></path>
    </svg>
  </span>
</a>
