{% if isHome %}
<footer class="site-footer-editorial">
  <span>© <b id="year">{{ currentYear }}</b> {{ site.name }}</span>
  <nav class="footer-links" aria-label="页脚链接">
    <a href="#top">回到页首 ↑</a>
    <a href="/notes/">短记</a>
    <a href="/feed.xml">订阅</a>
  </nav>
  <span>{{ site.alias }} · 开发、设计与思考</span>
</footer>
{% else %}
<footer class="site-footer-simple">
  <span>© <b id="year">{{ currentYear }}</b> {{ site.name }}</span>
  <nav class="footer-links" aria-label="页脚链接">
    <a href="/">首页</a>
    <a href="/notes/">短记</a>
    <a href="/feed.xml">订阅</a>
    <a href="{{ site.github }}" rel="me noopener noreferrer" target="_blank">GitHub ↗</a>
  </nav>
</footer>
{% endif %}
