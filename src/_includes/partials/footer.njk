{% if isHome %}
<footer
  class="scene closing-scene text-right"
  data-scene
  data-kind="closing"
  data-side="left"
  data-title="Continue"
  data-subtitle="下一篇，继续把问题写清楚"
>
  <div class="scene-copy" data-reveal>
    <span class="eyebrow">03 / Continue</span>
    <h2 class="closing-title">
      <span class="primary-line">继续探索，</span>
      <span>也继续把问题写清楚。</span>
    </h2>
  </div>
  <div class="footer-bottom">
    <span>© <b id="year"></b> {{ site.name }}</span>
    <span>{{ site.alias }} · Built with clarity and restraint.</span>
  </div>
</footer>
{% else %}
<footer class="site-footer-simple">
  <span>© <b id="year"></b> {{ site.name }}</span>
  <span>{{ site.alias }} · {{ site.role }}</span>
</footer>
{% endif %}
